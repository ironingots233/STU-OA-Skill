[
  {
    "name": "get_oa_news",
    "description": "获取指定天数内的OA通知列表。例如只查今天传入1，查这周传入7。",
    "parameters": {
      "type": "object",
      "properties": {
        "days_ago": {
          "type": "integer",
          "description": "要查询的过去天数。只查今天(当日)输入 1，查近一周输入 7，查近一月输入 30。"
        }
      },
      "required": ["days_ago"]
    }
  },
  {
    "name": "stu_oa_scraper",
    "description": "根据ID列表获取OA通知的正文详情。参数为整数数组 [id1, id2]。",
    "parameters": {
      "type": "object",
      "properties": {
        "item_ids": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "需要读取的ID数组。"
        }
      },
      "required": ["item_ids"]
    }
  }
]